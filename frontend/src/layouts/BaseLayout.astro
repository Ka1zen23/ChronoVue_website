---
import '../index.css';

const { title, description, canonical } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Prevent flash of wrong theme before JS hydrates -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <meta property="og:site_name" content="ChronoVue" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_BN" />
    <meta property="og:image" content="https://chronovue.co/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ChronoVue operational intelligence platform" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://chronovue.co/og-image.png" />

    <slot name="head" />

    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Decorative typography rails — parallax via setupTypographyParallax() -->
    <div class="typo-rails" aria-hidden="true">
      <div class="typo-rail typo-rail-l">
        <span data-typo-speed="0.12">VISIBILITY</span>
        <span data-typo-speed="0.22">COORDINATION</span>
        <span data-typo-speed="0.17">OPERATIONS</span>
        <span data-typo-speed="0.29">WORKFLOW</span>
        <span data-typo-speed="0.14">CAPACITY</span>
        <span data-typo-speed="0.21">INTELLIGENCE</span>
      </div>
      <div class="typo-rail typo-rail-r">
        <span data-typo-speed="0.25">FLOW</span>
        <span data-typo-speed="0.15">REAL-TIME</span>
        <span data-typo-speed="0.31">CLARITY</span>
        <span data-typo-speed="0.19">BOTTLENECK</span>
        <span data-typo-speed="0.11">CONTROL</span>
        <span data-typo-speed="0.24">DATA</span>
      </div>
    </div>

    <slot />
    <script>
      import { gsap } from 'gsap';
      import {
        setupHeroEntrance,
        setupScrollReveal,
        setupNavBehaviour,
        setupMagneticButtons,
        setupTypographyParallax,
      } from '../utils/animations';

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        gsap.globalTimeline.timeScale(100);
      }

      setTimeout(() => {
        setupHeroEntrance();
        setupScrollReveal();
        setupNavBehaviour();
        setupMagneticButtons();
        setupTypographyParallax();
      }, 60);
    </script>
  </body>
</html>
